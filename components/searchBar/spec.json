{
  "component": "search",
  "description": "검색 입력 컴포넌트. 선행형/후행형/CTA버튼형/응용형(팝업) 4가지 variant 제공",
  "naming_pattern": "search-{size} (size: 54, 48, 40, 36)",
  "variants": {
    "leading": "아이콘이 input 왼쪽에 위치 (선행형)",
    "trailing": "아이콘이 input 오른쪽에 위치 (후행형)",
    "cta": "input + 버튼 조합형",
    "popup": "최근 검색어 팝업 포함 응용형"
  },
  "sizes": {
    "54": { "class": "search-54", "icon": "search-icon-54", "font": "body1-r-18" },
    "48": { "class": "search-48", "icon": "search-icon-54", "font": "body1-r-18" },
    "40": { "class": "search-40", "icon": "search-icon-40", "font": "body2-r-16" },
    "36": { "class": "search-36", "icon": "search-icon-40", "font": "body3-r-14" }
  },
  "structure": {
    "leading": "search-{size} flex px-{n} gap-{n} > button.search-button + input",
    "trailing": "search-{size} flex pl-{n} pr-{n} space-between > input + button.search-button",
    "cta": "search-bar flex gap-8 > input.search-{size} + button",
    "popup": "search-wrapper > search-{size}(trailing) + search-popup[role=dialog]"
  },
  "popup_states": {
    "open": "search-popup active",
    "closed": "search-popup (active 없음)"
  },
  "notes": [
    "선행형: 아이콘 버튼 먼저, input 나중",
    "후행형: input 먼저, 아이콘 버튼 나중",
    "팝업형은 반드시 search-wrapper로 감싸야 함",
    "팝업 open/close는 search-popup에 active 클래스 토글",
    "input 포커스/클릭 시 팝업 열림, 래퍼 바깥 클릭 시 팝업 닫힘",
    "search-input 클래스는 팝업형 input에 JS 이벤트 바인딩용으로 추가",
    "접근성: search-popup에 role=dialog, aria-modal=true, aria-labelledby로 input id 연결"
  ],
  "examples": {
    "leading": "<div class=\"search-54 flex px-16 gap-12\">\n  <button type=\"button\" class=\"search-button\">\n    <i class=\"search-icon-54\"><span class=\"blind\">검색 버튼</span></i>\n  </button>\n  <input type=\"text\" class=\"body1-r-18\" placeholder=\"검색어를 입력해주세요\">\n</div>",
    "trailing": "<div class=\"search-54 flex pl-20 pr-16 space-between\">\n  <input type=\"text\" class=\"body1-r-18 w-full\" placeholder=\"검색어를 입력해주세요\">\n  <button type=\"button\" class=\"search-button\">\n    <i class=\"search-icon-54\"><span class=\"blind\">검색 버튼</span></i>\n  </button>\n</div>",
    "cta": "<div class=\"search-bar flex gap-8\">\n  <input type=\"text\" class=\"search-48 px-12\" placeholder=\"검색어를 입력해주세요\">\n  <button type=\"button\" class=\"slate-button-lg w-100\">검색</button>\n</div>",
    "popup": "<div class=\"search-wrapper\">\n  <div class=\"search-54 flex pl-20 pr-16 space-between\">\n    <input type=\"text\" class=\"body1-r-18 w-full search-input\" placeholder=\"검색어를 입력해주세요\" id=\"search-example\">\n    <button type=\"button\" class=\"search-button\">\n      <i class=\"search-icon-54\"><span class=\"blind\">검색 버튼</span></i>\n    </button>\n  </div>\n  <div class=\"search-popup py-8\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"search-example\">\n    <!-- 최근 검색어 목록 -->\n  </div>\n</div>"
  },
  "rules": [
    "search-wrapper 없이 팝업형 단독 사용 금지",
    "팝업 상태는 search-popup에 active 토글만 사용",
    "접근성 속성 (role, aria-modal, aria-labelledby) 반드시 포함"
  ],
  "do_not": [
    "팝업 show/hide를 인라인 스타일로 처리",
    "search-wrapper 없이 search-popup 단독 사용"
  ]
}