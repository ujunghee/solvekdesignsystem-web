{
  "component": "search",
  "description": "검색 입력 컴포넌트. 선행형/후행형/CTA버튼형/팝업형 4가지 variant 제공",
  "naming_pattern": "search-{size} (size: 54, 48, 40, 36)",
  "variants": {
    "leading": {
      "description": "아이콘이 input 왼쪽에 위치 (선행형)",
      "when_to_use": "사용자가 바로 타이핑을 시작할 것이 확실할 때, 검색 실행이 Enter(키보드)로 자연스럽게 이어질 때, 검색이 보조 기능일 때",
      "use_cases": ["모바일 검색창", "GIS 검색창", "콘텐츠 내 검색"]
    },
    "trailing": {
      "description": "아이콘이 input 오른쪽에 위치 (후행형)",
      "when_to_use": "사용자가 아이콘을 눌러서 검색할 가능성이 있을 때, Enter 대신 클릭/터치 실행을 보완해야 할 때, 검색을 간단한 액션으로 제공할 때",
      "use_cases": ["클릭이 잘 일어나는 위치에 배치할 경우(웹)", "빠른 조회가 필요할 경우"]
    },
    "cta": {
      "description": "input + 버튼 조합형 (버튼 강조형)",
      "when_to_use": "검색 결과가 중요한 행동으로 이어질 때, 사용자가 검색 실행을 명확히 인지해야 할 때, 입력 실수나 조건 확인이 필요한 경우",
      "use_cases": ["관리자 페이지", "필터/조건 검색"]
    },
    "popup": {
      "description": "최근 검색어 팝업 포함 응용형",
      "when_to_use": "최근 검색어 또는 자동완성을 제공해야 할 때",
      "use_cases": ["메인 검색창", "통합 검색"]
    }
  },
  "sizes": {
    "54": { "class": "search-54", "icon": "search-icon-54", "font": "body1-r-18" },
    "48": { "class": "search-48", "icon": "search-icon-54", "font": "body1-r-18" },
    "40": { "class": "search-40", "icon": "search-icon-40", "font": "body2-r-16" },
    "36": { "class": "search-36", "icon": "search-icon-40", "font": "body3-r-14" }
  },
  "structure": {
    "leading": "search-{size} flex px-{n} gap-{n} > button.search-button + input",
    "trailing": "search-{size} flex pl-{n} pr-{n} justify-between > input + button.search-button",
    "cta": "search-bar flex gap-8 > input.search-{size} + button",
    "popup": "search-wrapper > search-{size}(trailing) + search-popup[role=dialog]"
  },
  "popup_states": {
    "open": "search-popup active",
    "closed": "search-popup (active 없음)"
  },
  "notes": [
    "선행형: 아이콘 버튼 먼저, input 나중",
    "후행형: input 먼저, 아이콘 버튼 나중",
    "팝업형은 반드시 search-wrapper로 감싸야 함",
    "팝업 open/close는 search-popup에 active 클래스 토글",
    "input 포커스/클릭 시 팝업 열림, 래퍼 바깥 클릭 시 팝업 닫힘",
    "search-input 클래스는 팝업형 input에 JS 이벤트 바인딩용으로 추가",
    "접근성: search-popup에 role=dialog, aria-modal=true, aria-labelledby로 input id 연결"
  ],
  "examples": {
    "leading": "<div class=\"search-54 flex px-16 gap-12\">\n  <button type=\"button\" class=\"search-button\">\n    <i class=\"search-icon-54\"><span class=\"blind\">검색 버튼</span></i>\n  </button>\n  <input type=\"search\" class=\"body1-r-18\" placeholder=\"검색어를 입력해주세요\">\n</div>",
    "trailing": "<div class=\"search-54 flex pl-20 pr-16 justify-between\">\n  <input type=\"search\" class=\"body1-r-18 w-full\" placeholder=\"검색어를 입력해주세요\">\n  <button type=\"button\" class=\"search-button\">\n    <i class=\"search-icon-54\"><span class=\"blind\">검색 버튼</span></i>\n  </button>\n</div>",
    "cta": "<div class=\"search-bar flex gap-8\">\n  <input type=\"search\" class=\"search-48 px-12\" placeholder=\"검색어를 입력해주세요\">\n  <button type=\"button\" class=\"slate-button-lg w-100\">검색</button>\n</div>",
    "popup": "<div class=\"search-wrapper\">\n  <div class=\"search-54 flex pl-20 pr-16 justify-between\">\n    <input type=\"search\" class=\"body1-r-18 w-full search-input\" placeholder=\"검색어를 입력해주세요\" id=\"search-example\">\n    <button type=\"button\" class=\"search-button\">\n      <i class=\"search-icon-54\"><span class=\"blind\">검색 버튼</span></i>\n    </button>\n  </div>\n  <div class=\"search-popup py-8\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"search-example\">\n    <!-- 최근 검색어 목록 -->\n  </div>\n</div>"
  },
  "rules": [
    "search-wrapper 없이 팝업형 단독 사용 금지",
    "팝업 상태는 search-popup에 active 토글만 사용, 인라인 스타일 금지",
    "접근성 속성 (role=dialog, aria-modal=true, aria-labelledby) 반드시 포함"
  ],
  "do_not": [
    "팝업 show/hide를 인라인 스타일로 처리",
    "search-wrapper 없이 search-popup 단독 사용"
  ]
}