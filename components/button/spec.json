{
  "component": "button",
  "description": "사용자가 액션을 트리거하는 버튼",
  "naming_pattern": "{color}-button-{size} 또는 border-{color}-button-{size}",
  "base_rule": "색상과 사이즈가 하나로 합쳐진 클래스 사용",
  "sizes": ["54", "48", "40", "36", "32", "28"],
  "colors": {
    "blue": {
      "description": "주요 CTA",
      "when_to_use": "화면 내에서 가장 중요한 주요 액션에 사용",
      "use_cases": ["저장", "검색", "제출"]
    },
    "border-blue": {
      "description": "보조 액션 (blue 테두리)",
      "when_to_use": "주요 액션을 보조하는 행동에 사용",
      "use_cases": ["수정", "추가", "상세"]
    },
    "blue-50": {
      "description": "주요 액션 보완 (blue 밝은 배경)",
      "when_to_use": "주요 액션을 보완하는 부가 기능에 사용",
      "use_cases": ["문의", "옵션 설정", "목록보기", "테이블 액션"]
    },
    "slate": {
      "description": "중립 액션",
      "when_to_use": "화면 내에서 가장 중요한 주요 액션에 사용 (blue와 동급, 색상 톤만 다름)",
      "use_cases": ["저장", "검색", "제출"]
    },
    "border-slate": {
      "description": "중립 보조 액션 (slate 테두리)",
      "when_to_use": "낮은 우선순위의 보조 또는 취소/닫기에 사용",
      "use_cases": ["취소", "닫기"]
    },
    "slate-50": {
      "description": "약한 강조, 배경이 있는 중립 액션",
      "when_to_use": "주요 액션을 보완하는 부가 기능에 사용",
      "use_cases": ["문의", "옵션 설정", "목록보기", "테이블 액션"]
    },
    "transparent": {
      "description": "배경 없는 텍스트형 액션",
      "when_to_use": "링크성 또는 최소 강조 액션에 사용",
      "use_cases": ["더보기", "상세보기", "크게보기", "관심"]
    }
  },
  "disabled": {
    "class": "button-{size}",
    "description": "비활성 상태 버튼. 색상 접두사 없이 button-{size}만 사용",
    "example": "<button type='button' class='button-48' disabled>비활성</button>"
  },
  "icon_button": {
    "description": "아이콘 포함 버튼. icon-button-right/left 없이 gap-{n} flex align-center로 텍스트+아이콘 조합을 구성하며, 4가지 기능형으로 구분",
    "types": {
      "reset": {
        "description": "초기화 동작. transparent 계열에 사용",
        "icons": {
          "filter-reset-20": "검색필터 영역 초기화 아이콘 (18x18, slate-700)",
          "applied-reset-icon": "적용된 필터 초기화 아이콘 (17x16, #464C53)"
        },
        "examples": [
          "<button type='button' class='transparent-button-32 flex align-center gap-10'>\n  <span class='body2-m-16 color-slate-500'>초기화</span>\n  <i class='filter-reset-20'></i>\n  <span class='blind'>필터 초기화</span>\n</button>",
          "<button type='button' class='transparent-button-32 flex align-center gap-10'>\n  <span class='body2-m-16 color-slate-500'>초기화</span>\n  <i class='applied-reset-icon'></i>\n  <span class='blind'>적용된 필터 초기화</span>\n</button>"
        ]
      },
      "dropdown_toggle": {
        "description": "펼치기/접기. arrow-icon(24x24, 아래 방향) 사용, aria-expanded + .active 클래스를 JS로 동기화. .active 상태에서 arrow-icon 180도 회전",
        "icons": {
          "arrow-icon": "드롭다운/펼침 화살표 (24x24, #33363D)"
        },
        "examples": [
          "<button type='button' class='border-slate-button-40 flex align-center gap-8' aria-expanded='false'>\n  고급 검색\n  <i class='arrow-icon'></i>\n</button>",
          "<button type='button' class='border-slate-button-40 flex align-center gap-8 active' aria-expanded='true'>\n  고급 검색\n  <i class='arrow-icon'></i>\n</button>"
        ]
      },
      "remove": {
        "description": "닫기/삭제. chips-close-icon(12x12) 사용, span.blind로 동작 의미 전달. 칩(태그) 삭제는 components/chip/README.md 마크업 따름",
        "icons": {
          "chips-close-icon": "삭제 아이콘 (12x12, #475263)"
        },
        "examples": [
          "<button type='button' class='transparent-button-32 flex align-center gap-6'>\n  <span class='body2-m-16 color-slate-700'>대기</span>\n  <i class='chips-close-icon'></i>\n  <span class='blind'>삭제</span>\n</button>"
        ]
      },
      "filter_trigger": {
        "description": "검색필터 트리거. filter-icon/filter-icon.active 사용, .active 클래스 + aria-pressed를 JS로 동기화. .active 상태에서 border-slate-button-* → border-blue 톤(테두리·텍스트 blue-500)으로 전환, 아이콘은 filter-icon active(blue)로 교체",
        "icons": {
          "filter-icon": "필터 트리거 아이콘 (24x24, slate-700)",
          "filter-icon.active": "필터 트리거 아이콘 - 활성 (24x24, #1A76FF)"
        },
        "examples": [
          "<button type='button' class='border-slate-button-40 flex align-center gap-8' aria-pressed='false'>\n  검색필터\n  <i class='filter-icon'></i>\n</button>",
          "<button type='button' class='border-slate-button-40 flex align-center gap-8 active' aria-pressed='true'>\n  검색필터\n  <i class='filter-icon active'></i>\n</button>"
        ]
      }
    }
  },
  "examples": [
    "<button type='button' class='blue-button-40'>저장</button>",
    "<button type='button' class='border-blue-button-36'>수정</button>",
    "<button type='button' class='blue-50-button-36'>문의</button>",
    "<button type='button' class='slate-button-40'>확인</button>",
    "<button type='button' class='border-slate-button-36'>취소</button>",
    "<button type='button' class='slate-50-button-32'>목록보기</button>",
    "<button type='button' class='transparent-button-32'>더보기</button>",
    "<button type='button' class='button-48' disabled>비활성</button>"
  ],
  "view_toggle": {
    "description": "콘텐츠를 카드형/리스트형 등으로 전환해서 보는 보기 방식 토글 버튼 그룹",
    "naming_pattern": "view-toggle (BEM: view-toggle__btn, view-toggle__icon--active/inactive)",
    "structure": {
      "group": "div.view-toggle[role=group][aria-label] > button.view-toggle__btn[aria-pressed]*",
      "button": "button.view-toggle__btn > i.{icon}-icon.view-toggle__icon--active + i.{icon}-icon.view-toggle__icon--inactive + span.body2-r-16.color-slate-700"
    },
    "icons": {
      "dashboards-blue-icon": "카드형 보기 아이콘 (선택됨, 20x20, #1A76FF)",
      "dashboards-gray-icon": "카드형 보기 아이콘 (선택 안 됨, 20x20, #64748B)",
      "list-blue-icon": "리스트형 보기 아이콘 (선택됨, 20x20, #1A76FF)",
      "list-gray-icon": "리스트형 보기 아이콘 (선택 안 됨, 20x20, #64748B)"
    },
    "states": {
      "active": "선택된 버튼에 .active 클래스 + aria-pressed='true', view-toggle__icon--active만 표시",
      "inactive": "aria-pressed='false', view-toggle__icon--inactive만 표시"
    },
    "rules": [
      "그룹 wrapper에 role='group' + aria-label로 그룹 목적 명시",
      "각 버튼은 button[type=button] + aria-pressed 속성 필수",
      "아이콘은 dashboards-blue/gray-icon, list-blue/gray-icon 등 정의된 클래스만 사용",
      "버튼 텍스트는 span.body2-r-16.color-slate-700 사용",
      "한 그룹 내에서 하나의 버튼만 active 상태를 가짐",
      ".active 클래스와 aria-pressed는 JS로 토글 (JS 패턴 7-7 참조)"
    ]
  },
  "notes": [
    "54 사이즈는 현재 border-slate 색상에만 정의됨 (border-slate-button-54). 다른 색상의 54 사이즈는 CSS 정의 전까지 사용 금지"
  ],
  "rules": [
    "반드시 type 속성 명시 (button/submit/reset 중 하나)",
    "정의된 클래스만 사용",
    "naming_pattern 외 임의 클래스 생성 금지",
    "아이콘 버튼은 반드시 flex align-center 추가",
    "disabled 버튼은 색상 접두사 없이 button-{size} + disabled 속성",
    "54 사이즈는 border-slate 색상에서만 사용 (다른 색상은 미정의)"
  ],
  "do_not": [
    "사이즈 없이 색상만 단독 사용",
    "div/span으로 버튼 대체",
    "아이콘 버튼에서 flex align-center 누락",
    "disabled 버튼에 색상 클래스 사용",
    "view-toggle 그룹에 aria-pressed 속성 누락",
    "view-toggle에서 정의되지 않은 아이콘 클래스 또는 인라인 style로 색상 변경",
    "펼치기/접기, 검색필터 트리거 버튼에서 .active 클래스와 aria-expanded/aria-pressed 동기화 누락",
    "icon_button에서 정의되지 않은 아이콘 클래스 또는 인라인 style로 색상 변경"
  ]
}