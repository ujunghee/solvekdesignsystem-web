      "use_cases": ["저장", "검색", "제출"]
    },
    "border-blue": {
      "description": "보조 액션 (blue 테두리)",
      "when_to_use": "주요 액션을 보조하는 행동에 사용",
      "use_cases": ["수정", "추가", "상세"]
    },
    "blue-50": {
      "description": "주요 액션 보완 (blue 밝은 배경)",
      "when_to_use": "주요 액션을 보완하는 부가 기능에 사용",
      "use_cases": ["문의", "옵션 설정", "목록보기", "테이블 액션"]
    },
    "slate": {
      "description": "중립 액션",
      "when_to_use": "화면 내에서 가장 중요한 주요 액션에 사용 (blue와 동급, 색상 톤만 다름)",
      "use_cases": ["저장", "검색", "제출"]
    },
    "border-slate": {
      "description": "중립 보조 액션 (slate 테두리)",
      "when_to_use": "낮은 우선순위의 보조 또는 취소/닫기에 사용",
      "use_cases": ["취소", "닫기"]
    },
    "slate-50": {
      "description": "약한 강조, 배경이 있는 중립 액션",
      "when_to_use": "주요 액션을 보완하는 부가 기능에 사용",
      "use_cases": ["문의", "옵션 설정", "목록보기", "테이블 액션"]
    },
    "transparent": {
      "description": "배경 없는 텍스트형 액션",
      "when_to_use": "링크성 또는 최소 강조 액션에 사용",
      "use_cases": ["더보기", "상세보기", "크게보기", "관심"]
    }
  },
  "disabled": {
    "class": "button-{size}",
    "description": "비활성 상태 버튼. 색상 접두사 없이 button-{size}만 사용",
    "example": "<button type='button' class='button-48' disabled>비활성</button>"
  },
  "icon_button": {
    "description": "아이콘 포함 버튼. 아이콘 위치에 따라 클래스 추가",
    "patterns": {
      "icon-button-right": "텍스트 왼쪽, 아이콘 오른쪽",
      "icon-button-left": "아이콘 왼쪽, 텍스트 오른쪽"
    },
    "icons": {
      "chevron-right-white": "흰색 화살표 (blue, slate 계열에 사용)",
      "chevron-right-slate-700": "진한 회색 화살표 (slate-50, transparent 계열에 사용)"
    },
    "examples": [
      "<button type='button' class='blue-button-48 icon-button-right flex align-center'>\n  저장\n  <span class='chevron-right-white'></span>\n</button>",
      "<button type='button' class='slate-50-button-48 icon-button-left flex align-center'>\n  <span class='chevron-right-slate-700'></span>\n  목록보기\n</button>"
    ]
  },
  "examples": [
    "<button type='button' class='blue-button-40'>저장</button>",
    "<button type='button' class='border-blue-button-36'>수정</button>",
    "<button type='button' class='blue-50-button-36'>문의</button>",
    "<button type='button' class='slate-button-40'>확인</button>",
    "<button type='button' class='border-slate-button-36'>취소</button>",
    "<button type='button' class='slate-50-button-32'>목록보기</button>",
    "<button type='button' class='transparent-button-32'>더보기</button>",
    "<button type='button' class='button-48' disabled>비활성</button>"
  ],
  "rules": [
    "반드시 type 속성 명시 (button/submit/reset 중 하나)",
    "정의된 클래스만 사용",
    "naming_pattern 외 임의 클래스 생성 금지",
    "아이콘 버튼은 반드시 flex align-center 추가",
    "disabled 버튼은 색상 접두사 없이 button-{size} + disabled 속성"
  ],
  "do_not": [
    "사이즈 없이 색상만 단독 사용",
    "div/span으로 버튼 대체",
    "아이콘 버튼에서 flex align-center 누락",
    "disabled 버튼에 색상 클래스 사용"
  ]
}